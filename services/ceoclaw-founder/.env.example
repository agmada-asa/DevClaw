# ─── Z.AI GLM (required) ──────────────────────────────────────────────────────
ZAI_API_KEY=your_zai_api_key_here
ZAI_BASE_URL=https://open.bigmodel.cn/api/paas/v4

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── CEOClaw agent settings ───────────────────────────────────────────────────
PORT=3050
CEOCLAW_AGENT_ENGINE=direct          # direct (Z.AI GLM) | openclaw (CLI) | heuristic
CEOCLAW_AUTO_START=false
CEOCLAW_LOOP_INTERVAL_MS=3600000
CEOCLAW_LANDING_PAGE_URL=https://devclaw.ai
CEOCLAW_DAILY_MESSAGE_LIMIT=20
CEOCLAW_MAX_PROSPECTS_PER_CAMPAIGN=20
CEOCLAW_MIN_FIT_SCORE=65
CEOCLAW_DEFAULT_SEARCH_QUERY=CTO startup software
CEOCLAW_QUALIFY_TIMEOUT_MS=90000       # max per-prospect qualification latency
CEOCLAW_MESSAGE_TIMEOUT_MS=90000       # max per-prospect message generation latency
CEOCLAW_DISCOVERY_TIMEBOX_MS=          # optional global discovery stage timebox
CEOCLAW_QUALIFICATION_TIMEBOX_MS=      # optional global qualification stage timebox
CEOCLAW_MESSAGE_TIMEBOX_MS=            # optional global message-generation stage timebox
CEOCLAW_SENDING_TIMEBOX_MS=            # optional global sending stage timebox
CEOCLAW_PROGRESS_OUTPUT_DIR=./ceoclaw-output/campaign-progress

# ─── LinkedIn (required for sales outreach) ───────────────────────────────────
LINKEDIN_EMAIL=
LINKEDIN_PASSWORD=
LINKEDIN_SESSION_PATH=./linkedin-session.json
