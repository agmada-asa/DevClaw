PORT=3050

# ─── Founder loop ─────────────────────────────────────────────────────────────
# The loop wakes up every INTERVAL, asks OpenClaw what to do, runs it, sleeps.
CEOCLAW_LOOP_INTERVAL_MS=3600000      # 1 hour between iterations (default)
CEOCLAW_AUTO_START=false              # Set to 'true' to start on boot

# ─── AI agent engine ──────────────────────────────────────────────────────────
# 'openclaw' (default) — all AI tasks go through OpenClaw CLI gateway
# 'direct'             — uses @devclaw/llm-router directly (no CLI required)
CEOCLAW_AGENT_ENGINE=openclaw

# ─── OpenClaw CLI (required when CEOCLAW_AGENT_ENGINE=openclaw) ───────────────
OPENCLAW_CLI_BIN=openclaw
OPENCLAW_CLI_MODE=gateway
OPENCLAW_CLI_TIMEOUT_MS=120000
OPENCLAW_GATEWAY_URL=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_TO=+15555550123

# ─── Sales / LinkedIn ─────────────────────────────────────────────────────────
LINKEDIN_EMAIL=your@email.com
LINKEDIN_PASSWORD=yourpassword
LINKEDIN_SESSION_PATH=./linkedin-session.json
LINKEDIN_HEADLESS=true
CEOCLAW_DAILY_MESSAGE_LIMIT=20
CEOCLAW_DELAY_BETWEEN_ACTIONS_MS=4000
CEOCLAW_DEFAULT_SEARCH_QUERY=CTO startup software
CEOCLAW_MAX_PROSPECTS_PER_CAMPAIGN=20
CEOCLAW_MIN_FIT_SCORE=65

# ─── Output directory (landing pages, SEO content, campaign plans) ────────────
CEOCLAW_OUTPUT_DIR=./ceoclaw-output

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
